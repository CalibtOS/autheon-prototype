// AUTHEON Version 1 database draft — PostgreSQL target.
// See logical-model.md for constraints that DBML cannot express (partial unique indexes, RLS, and transition rules).
// 2026-07-14 (PRD v2.1 follow-up, same version) — important-vehicle-info conditional rules: added jobs.red_license_plate_number (§16 FZV dealer transfer plate, operator-bound); documented that licenseplate is app-required when registered and null when deregistered.
// 2026-07-13 (PRD v2.0, F-01) — removed deprecated master_data_change_type.daily_limit_override enum value. Documented that drivers.probation_job_limit is a per-driver snapshot seeded at creation from app_settings 'driver.acceptance.probationJobCount' (application-layer default, literal column default is a fallback only); no structural change to columns.
// Last updated: 2026-07-10 (PRD v2.0) — no structural change. Annotated drivers.driver_code semantics (F-03: system-assigned, immutable, never reused) and documented same-day per-leg time-window rule (F-04) in logical-model.md. Probation UI, Infopoint View/Download, branding/domain/Report-Problem-timing are UI/open items with no schema impact.
// 2026-07-09 (PRD v1.9, F-01) — replaced drivers.daily_job_limit with the one-time probation model (probation_job_limit + probation_cleared_at); removed master_data_change_type.daily_limit_override; renamed app_settings key driver.acceptance.defaultDailyJobLimit -> driver.acceptance.probationJobCount.
// 2026-07-03 — aligned upload-core asset model, document versioning, infopoint/problem upload links, and explicit job location windows with autheon-be TypeORM sync target.

Enum user_status {
  pending_verification
  active
  suspended
  inactive
}

Enum user_role {
  user
  admin
  driver
}

Enum job_status {
  draft
  published
  assigned
  accepted
  performed
  cancelled
  special_case
}

Enum assignment_mode {
  marketplace  // job published to marketplace; any eligible driver may accept
  direct       // job assigned directly to a specific driver
}

Enum assignment_type {
  direct_assignment
  marketplace_acceptance
  reassignment
}

Enum location_role {
  pickup
  delivery
}

Enum problem_type {
  cancel_order
  not_performable
}

Enum problem_status {
  submitted
  resolved
  withdrawn
}

Enum document_type {
  invoice
  fuel_receipt
  toll_receipt
  delivery_note
  waiting_time_evidence
  other_proof
  other_receipt
  transport_order
}

Enum document_review_status {
  missing
  uploaded
  under_review
  accepted
  rejected
  correction_required
}

Enum settlement_status {
  not_started
  pending
  processed
  paid
  needs_clarification
  closed
}

Enum invoice_payment_status {
  invoice_missing
  invoice_received
  paid
  needs_clarification
}

Enum cancellation_actor {
  driver
  admin
  customer
}

// Important vehicle info (Design Direction Board 07/2026 §5; resolved 2026-07-14
// via prd.json resolved_defaults.vehicle_important_info_v1). Nullable on jobs —
// null means "not specified"; never required for publish/direct assign.
Enum vehicle_registration_status {
  registered
  deregistered
}

Enum master_data_change_type {
  bank_details
  address
  vehicle_info
  license
  contact
}

Enum notification_channel {
  in_app
  push
  email
}

Enum message_delivery_status {
  pending
  processing
  delivered
  failed
  cancelled
}

Table users {
  id uuid [pk]
  keycloak_id varchar(36) [unique] // nullable until Keycloak provisioning completes; partial unique index where not null
  email varchar(255) [not null, unique]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  status user_status [not null, default: 'pending_verification']
  roles text [not null, default: 'user'] // TypeORM simple-array of user_role values
  email_verified boolean [not null, default: false]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz
}

Table drivers {
  id uuid [pk]
  user_id uuid [not null, unique]
  driver_code varchar(64) [not null, unique]  // F-03: system-assigned from a monotonic sequence, immutable after creation, never reused (even after block/inactive/archive/soft-delete/departure); exact format client-defined (see prd.json production_open_questions)
  company_name varchar(255) [not null]
  contact_name varchar(255)
  street varchar(255)
  house_number varchar(32)
  postal_code varchar(32)
  city varchar(128)
  country_code char(2) [not null, default: 'DE']
  phone varchar(64)
  notes text
  // One-time probation model (F-01, replaces former per-day daily_job_limit).
  probation_job_limit smallint [not null, default: 3]  // Per-driver SNAPSHOT of the probation allowance AND Performed-count release threshold. Seeded at driver creation from app_settings 'driver.acceptance.probationJobCount' by the application layer (see logical-model.md); the literal default here is only a safety fallback when the setting is unavailable. Snapshot semantics: later changes to the app_settings value do NOT retroactively affect existing drivers. Remaining allowance is derived (probation_job_limit minus count of Performed jobs from job_status_history), not stored.
  probation_cleared_at timestamptz  // set when driver is released from probation (auto after probation_job_limit Performed jobs, or manual admin release); null = still on probation
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table customers {
  id uuid [pk]
  name varchar(255) [not null]
  customer_type varchar(100)
  billing_reference varchar(255)
  contact_name varchar(255)
  contact_email citext
  contact_phone varchar(64)
  billing_notes text
  operational_instructions text
  notes text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  archived_at timestamptz
}

Table locations {
  id uuid [pk]
  name varchar(255) [not null]
  street varchar(255) [not null]
  house_number varchar(32)
  postal_code varchar(32) [not null]
  city varchar(128) [not null]
  country_code char(2) [not null, default: 'DE']
  contact_name varchar(255)
  alternate_contact_name varchar(255)
  phone varchar(64)
  second_phone varchar(64)
  email citext
  notes text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  archived_at timestamptz
}

Table jobs {
  id uuid [pk]
  tour_number varchar(32) [not null, unique]
  category varchar(100) [not null]
  customer_id uuid [not null]
  customer_name_snapshot varchar(255) [not null]
  customer_type_snapshot varchar(100)
  customer_billing_reference_snapshot varchar(255)
  customer_billing_notes_snapshot text
  customer_instructions_snapshot text
  operational_status job_status [not null, default: 'draft']
  current_driver_id uuid
  distance_km numeric(10,2) // canonical tour distance: system estimate or admin-entered value (single field — no separate override or source column)
  vehicle_manufacturer varchar(128)
  vehicle_model varchar(255) [not null]
  vehicle_type varchar(100) [not null]
  licenseplate varchar(32)
  vin varchar(17)
  axle_type varchar(32) [not null]
  // Important vehicle info — announcement metadata (DDB 07/2026 §5) with
  // conditional capture rules (2026-07-14): licenseplate is required by the
  // application when registration is 'registered' (or unspecified) and MUST be
  // null when 'deregistered' (a deregistered vehicle carries no valid plate);
  // when red_license_plates = true the application requires
  // red_license_plate_number. No filter dimension in V1.
  vehicle_registration_status vehicle_registration_status // nullable = not specified
  electric_vehicle boolean [not null, default: false]
  red_license_plates boolean [not null, default: false]
  // German red transfer plate (rotes Kennzeichen, §16 FZV): district code +
  // recognition number starting 06 (dealer/workshop series; 05 = inspection,
  // 07 = classic cars). Assigned to the OPERATOR, not the vehicle — captured
  // per tour, not in a vehicle master table. Example: 'K-06 1234'.
  red_license_plate_number varchar(32)
  internal_notes text
  driver_visible_notes text
  // Determines publish flow and notification strategy
  assignment_mode assignment_mode [not null, default: 'marketplace']
  // Marketplace filter dimensions — matched against notification_preferences.postal_areas / vehicle_type / axle_type
  required_vehicle_type varchar(100)
  required_axle_type varchar(32)
  pickup_postal_area varchar(16)
  document_review_summary document_review_status [not null, default: 'missing']
  settlement_state settlement_status [not null, default: 'not_started']
  created_at timestamptz [not null]
  created_by_user_id uuid [not null]
  updated_at timestamptz [not null]
  // Denormalized for fast SLA/settlement queries — authoritative source is job_status_history
  accepted_at timestamptz
  performed_at timestamptz
  cancelled_at timestamptz
  cancelled_by_user_id uuid
  cancellation_actor cancellation_actor
  cancellation_reason_code varchar(100)
  cancellation_reason_text text  // driver-facing message when cancellation_actor is admin/dispatching; also used for driver cancel explanation
}

Table job_locations {
  id uuid [pk]
  job_id uuid [not null]
  location_type location_role [not null]
  sequence int [not null, default: 0]
  location_id uuid
  name varchar(255) [not null] // immutable snapshot
  street varchar(255) [not null] // immutable snapshot
  house_number varchar(32)
  postal_code varchar(32) [not null] // immutable snapshot
  city varchar(128) [not null] // immutable snapshot
  country_code char(2) [not null]
  contact_name varchar(255)
  alternate_contact_name varchar(255)
  phone varchar(64)
  second_phone varchar(64)
  email citext
  notes text
  scheduled_date date
  window_start time
  window_end time  // F-04: window is same-day only; window_end >= window_start (no cross-midnight). Pickup and delivery legs may still have different scheduled_date.
  window_is_flexible boolean [not null, default: false]
  completed_at timestamptz

  indexes {
    (job_id, location_type, sequence) [unique]
    (postal_code, scheduled_date)
  }
}

Table job_assignments {
  id uuid [pk]
  job_id uuid [not null]
  driver_id uuid [not null]
  assignment_type assignment_type [not null]
  assigned_by_user_id uuid
  started_at timestamptz [not null]
  ended_at timestamptz
  end_reason varchar(100)
  notes text
}

Table job_status_history {
  id uuid [pk]
  job_id uuid [not null]
  previous_status job_status
  next_status job_status [not null]
  occurred_at timestamptz [not null]
  actor_user_id uuid
  evidence_document_file_id uuid
  comment text
  metadata jsonb

  indexes {
    (job_id, occurred_at)
  }
}

Table job_distance_estimates {
  id uuid [pk]
  job_id uuid [not null]
  provider varchar(100)
  routing_profile varchar(100)
  distance_km numeric(10,2) [not null]
  raw_response jsonb
  calculated_at timestamptz [not null]
  calculated_by_user_id uuid
  is_manual_override boolean [not null, default: false]
  override_reason text
}

Table job_financials {
  id uuid [note: 'BE surrogate PK; logical 1:1 with jobs']
  job_id uuid [unique, not null]
  // Operational V1 amounts (prototype + PRD)
  revenue_amount numeric(12,2) [note: 'Customer revenue / price']
  driver_offer_amount numeric(12,2) [note: 'Driver marketplace compensation']
  expenses_amount numeric(12,2)
  // Optional net/gross snapshot (BE + prototype)
  total_net numeric(12,2)
  total_gross numeric(12,2)
  // BE property `currency` maps to this column name in design docs
  currency_code char(3) [not null, default: 'EUR', note: 'BE column: currency']
  // BE property `vatRate` / column vat_rate
  tax_rate numeric(5,2) [note: 'BE column: vat_rate']
  invoice_received boolean [not null, default: false]
  admin_invoice_override boolean
  payment_status invoice_payment_status [not null, default: 'invoice_missing']
  notes text
  updated_at timestamptz [not null]
  updated_by_user_id uuid
  settlement_initiated_by uuid
  settlement_initiated_at timestamptz
}

Table job_problem_reports {
  id uuid [pk]
  job_id uuid [not null]
  reported_by_user_id uuid
  reported_by_actor cancellation_actor [not null]
  reported_by_customer_id uuid
  problem_type problem_type [not null]
  reason_code varchar(100) [not null]
  reason_text text
  status_before_problem job_status [not null]
  report_status problem_status [not null, default: 'submitted']
  submitted_at timestamptz [not null]
  resolved_at timestamptz
  resolved_by_user_id uuid
  resolution_action varchar(100)
  resolution_note text
}

Table problem_report_evidence {
  id uuid [pk]
  problem_report_id uuid [not null]
  upload_asset_id uuid [not null]
  original_filename_snapshot varchar(500)
  created_at timestamptz [not null]
}

Table job_documents {
  id uuid [pk]
  job_id uuid [not null]
  document_type document_type [not null]
  source varchar(32) [not null] // driver_pwa | admin_off_channel | generated — drivers replace driver_pwa only
  uploaded_by_user_id uuid
  review_status document_review_status [not null, default: 'uploaded']
  processed_at timestamptz
  processed_by_user_id uuid
  rejection_reason text
  supplier_invoice_number varchar(100)
  supplier_invoice_date date
  notes text
  current_file_id uuid
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table document_files {
  id uuid [pk]
  job_document_id uuid
  upload_asset_id uuid [not null]
  original_filename varchar(500) [not null]
  mime_type varchar(255) [not null]
  file_size_bytes bigint [not null]
  sha256 char(64)
  storage_key varchar(1024) [not null, unique]
  scan_status varchar(32) [not null, default: 'pending']
  scanned_at timestamptz
  uploaded_by_user_id uuid [not null]
  uploaded_at timestamptz [not null]
  supersedes_file_id uuid
  superseded_at timestamptz
}

Table job_document_reviews {
  id uuid [pk]
  job_document_id uuid [not null]
  review_status document_review_status [not null]
  reviewer_user_id uuid [not null]
  reason text
  occurred_at timestamptz [not null]
}

Table generated_job_documents {
  id uuid [pk]
  job_id uuid [not null]
  document_file_id uuid [not null]
  document_kind varchar(64) [not null] // transport_order
  version_number int [not null]
  generated_at timestamptz [not null]
  generated_by_user_id uuid
  is_current boolean [not null, default: true]

  indexes {
    (job_id, document_kind, version_number) [unique]
  }
}

Table master_data_change_requests {
  id uuid [pk]
  driver_id uuid [not null]
  requested_by_user_id uuid [not null]
  status varchar(32) [not null, default: 'open'] // open | approved | rejected
  change_type master_data_change_type [not null]  // discriminator for admin queue filtering and per-type validation
  requester_note text [not null]
  current_snapshot jsonb [not null]
  proposed_changes jsonb [not null]
  created_at timestamptz [not null]
  resolved_at timestamptz
  resolved_by_user_id uuid
  // Review audit — who reviewed and when
  reviewed_by_user_id uuid
  reviewed_at timestamptz
  admin_note text
}

Table infopoint_documents {
  id uuid [pk]
  title varchar(255) [not null]
  description text
  category varchar(100)
  scope varchar(100) [not null, default: 'global']
  version_label varchar(64)
  upload_asset_id uuid [not null]
  is_visible boolean [not null, default: true]
  published_at timestamptz [not null]
  updated_at timestamptz [not null]
  updated_by_user_id uuid
}

Table upload_assets {
  id uuid [pk]
  storage_key varchar(512) [not null, unique]
  original_name varchar(255) [not null]
  filename varchar(255) [not null]
  mime_type varchar(128) [not null]
  extension varchar(16) [not null]
  size int [not null]
  checksum varchar(64) [not null]
  access varchar(32) [not null] // public | private
  purpose varchar(64) [not null] // generic @autheon/shared UploadPurpose value, e.g. private-document-or-image
  owner_id uuid [not null]
  status varchar(32) [not null, default: 'active']
  url varchar(1024)
  relative_path varchar(1024)
  variants jsonb [not null, default: '[]']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table infopoint_news {
  id uuid [pk]
  subject varchar(255) [not null]
  body text [not null]
  published_at timestamptz [not null]
  is_visible boolean [not null, default: true]
  notify_in_app boolean [not null, default: true]
  notify_push boolean [not null, default: false]
  created_by_user_id uuid [not null]
  updated_at timestamptz [not null]
}

Table infopoint_news_reads {
  news_id uuid [not null]
  user_id uuid [not null]
  read_at timestamptz [not null]

  indexes {
    (news_id, user_id) [pk]
  }
}

Table notification_preferences {
  user_id uuid [pk]
  push_enabled boolean [not null, default: false]
  notify_published_jobs boolean [not null, default: false]
  notify_postal_area boolean [not null, default: false]
  // Array of postal area codes — replaces single pickup_postal_prefix to support multi-area subscriptions
  postal_areas text[] [not null, default: '{}']
  vehicle_type varchar(100)
  axle_type varchar(32)
  updated_at timestamptz [not null]
}

Table push_subscriptions {
  id uuid [pk]
  user_id uuid [not null]
  endpoint text [not null, unique]
  p256dh_key text [not null]
  auth_key text [not null]
  user_agent text
  created_at timestamptz [not null]
  last_seen_at timestamptz
  revoked_at timestamptz
  // Set to false on HTTP 410 Gone from push service — prevents retrying expired subscriptions
  is_active boolean [not null, default: true]
}

Table user_notifications {
  id uuid [pk]
  user_id uuid [not null]
  notification_type varchar(100) [not null]
  job_id uuid
  title varchar(255) [not null]
  body text
  deep_link varchar(1024)
  created_at timestamptz [not null]
  read_at timestamptz
}

Table outbox_events {
  id uuid [pk]
  event_type varchar(100) [not null]
  aggregate_type varchar(100) [not null]
  aggregate_id uuid [not null]
  payload jsonb [not null]
  occurred_at timestamptz [not null]
  available_at timestamptz [not null]
  status message_delivery_status [not null, default: 'pending']
  deduplication_key varchar(255) [unique]
}

Table notification_deliveries {
  id uuid [pk]
  user_notification_id uuid [not null]
  channel notification_channel [not null]
  status message_delivery_status [not null, default: 'pending']
  attempt_count int [not null, default: 0]
  last_attempt_at timestamptz
  delivered_at timestamptz
  error_message text
}

Table feature_flags {
  key varchar(100) [pk]
  is_enabled boolean [not null, default: false]
  description text
  updated_at timestamptz [not null]
  updated_by_user_id uuid
}

Table app_settings {
  key varchar(100) [pk]  // canonical keys: branding.display, operational.policies, cancellation.policies, driver.acceptance.probationJobCount (F-01: source of the seed value copied into drivers.probation_job_limit at driver creation; replaces driver.acceptance.defaultDailyJobLimit)
  value jsonb [not null]
  updated_at timestamptz [not null]
  updated_by_user_id uuid
}

Table audit_events {
  id uuid [pk]
  occurred_at timestamptz [not null]
  actor_user_id uuid
  action_key varchar(100) [not null]
  entity_type varchar(100) [not null]
  entity_id uuid
  job_id uuid
  metadata jsonb

  indexes {
    (job_id, occurred_at)
    (entity_type, entity_id, occurred_at)
  }
}

Ref: drivers.user_id > users.id

Ref: jobs.customer_id > customers.id
Ref: jobs.current_driver_id > drivers.id
Ref: jobs.created_by_user_id > users.id
Ref: jobs.cancelled_by_user_id > users.id
Ref: job_locations.job_id > jobs.id
Ref: job_locations.location_id > locations.id
Ref: job_assignments.job_id > jobs.id
Ref: job_assignments.driver_id > drivers.id
Ref: job_assignments.assigned_by_user_id > users.id
Ref: job_status_history.job_id > jobs.id
Ref: job_status_history.actor_user_id > users.id
Ref: job_status_history.evidence_document_file_id > document_files.id
Ref: job_distance_estimates.job_id > jobs.id
Ref: job_distance_estimates.calculated_by_user_id > users.id
Ref: job_financials.job_id > jobs.id

Ref: job_problem_reports.job_id > jobs.id
Ref: job_problem_reports.reported_by_user_id > users.id
Ref: job_problem_reports.reported_by_customer_id > customers.id
Ref: job_problem_reports.resolved_by_user_id > users.id
Ref: problem_report_evidence.problem_report_id > job_problem_reports.id
Ref: problem_report_evidence.upload_asset_id > upload_assets.id

Ref: job_documents.job_id > jobs.id
Ref: job_documents.uploaded_by_user_id > users.id
Ref: job_documents.processed_by_user_id > users.id
Ref: document_files.job_document_id > job_documents.id
Ref: document_files.upload_asset_id > upload_assets.id
Ref: document_files.supersedes_file_id > document_files.id
Ref: job_documents.current_file_id > document_files.id
Ref: job_document_reviews.job_document_id > job_documents.id
Ref: job_document_reviews.reviewer_user_id > users.id
Ref: generated_job_documents.job_id > jobs.id
Ref: generated_job_documents.document_file_id > document_files.id

Ref: job_financials.settlement_initiated_by > users.id

Ref: master_data_change_requests.driver_id > drivers.id
Ref: master_data_change_requests.requested_by_user_id > users.id
Ref: master_data_change_requests.resolved_by_user_id > users.id
Ref: master_data_change_requests.reviewed_by_user_id > users.id
Ref: infopoint_documents.upload_asset_id > upload_assets.id
Ref: infopoint_documents.updated_by_user_id > users.id
Ref: infopoint_news.created_by_user_id > users.id
Ref: infopoint_news_reads.news_id > infopoint_news.id
Ref: infopoint_news_reads.user_id > users.id

Ref: notification_preferences.user_id > users.id
Ref: push_subscriptions.user_id > users.id
Ref: user_notifications.user_id > users.id
Ref: user_notifications.job_id > jobs.id
Ref: notification_deliveries.user_notification_id > user_notifications.id
Ref: feature_flags.updated_by_user_id > users.id
Ref: app_settings.updated_by_user_id > users.id
Ref: audit_events.actor_user_id > users.id
Ref: audit_events.job_id > jobs.id
