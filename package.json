{
  "name": "autheon-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Static AUTHEON frontend prototype with Playwright E2E and regression tests.",
  "scripts": {
    "dev": "http-server . -a 127.0.0.1 -p 4173 -c-1",
    "test:e2e": "playwright test tests/e2e --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:smoke": "playwright test tests/e2e/smoke --project=chromium",
    "test:regression": "playwright test tests/regression --project=chromium",
    "test:regression:update": "playwright test tests/regression --update-snapshots --project=chromium",
    "test:regression:visual": "playwright test tests/regression --grep @visual-regression --project=chromium",
    "test:regression:visual:update": "playwright test tests/regression --grep @visual-regression --update-snapshots --project=chromium",
    "test:report": "playwright show-report",
    "test:install-browsers": "playwright install chromium",
    "test:list": "playwright test --list",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "^25.9.3",
    "dotenv": "^16.4.7",
    "http-server": "^14.1.1",
    "typescript": "^6.0.3"
  }
}
